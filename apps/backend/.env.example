# Backend Environment Variables
NODE_ENV=development
PORT=3000

# Database Configuration
MONGODB_URI=mongodb://admin:password123@localhost:27017/ai_blog?authSource=admin
REDIS_URL=redis://:redis_password123@localhost:6379

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
# For production, use comma-separated origins:
# CORS_ORIGIN=https://your-app.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# LLM Configuration
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Memory Configuration
MEMORY_SHORT_TERM_WINDOW=10
MEMORY_LONG_TERM_IMPORTANCE_THRESHOLD=0.5
MEMORY_AUTO_SUMMARIZE_THRESHOLD=20

# RAG Configuration
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Dify Configuration (Optional - for workflow execution)
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=your-dify-api-key-here
DIFY_WORKFLOW_ID=your-workflow-id-here
