{
  "permissions": {
    "allow": [
      "pnpm install",
      "pnpm run dev",
      "pnpm run build",
      "pnpm run test",
      "pnpm run lint",
      "pnpm run clean",
      "pnpm --filter @ai-blog/backend *",
      "pnpm --filter @ai-blog/frontend *",
      "pnpm --filter @ai-blog/extension *",
      "nest start",
      "nest build",
      "vite",
      "turbo run *",
      "docker-compose *",
      "docker compose *",
      "mkdir -p .claude/*",
      "mkdir -p apps/*",
      "git status",
      "git diff",
      "git log",
      "git add",
      "git commit *",
      "git branch",
      "git checkout",
      "git switch",
      "git push",
      "git pull",
      "git fetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"if (Test-Path '${CLAUDE_PROJECT_DIR}/node_modules/.bin/eslint') { npx eslint --fix '${CLAUDE_FILE_PATH}' 2>$null; Write-Host 'Linted' }\""
          }
        ]
      }
    ]
  },
  "model": "claude-sonnet-4-6"
}
