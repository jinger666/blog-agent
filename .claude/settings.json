{
  "permissions": {
    "allow": [
      "Pnpm install",
      "Pnpm run dev",
      "Pnpm run build",
      "Pnpm run test",
      "Pnpm run lint",
      "Pnpm run clean",
      "Pnpm --filter @ai-blog/backend *",
      "Pnpm --filter @ai-blog/frontend *",
      "Pnpm --filter @ai-blog/extension *",
      "Nest start",
      "Nest build",
      "Vite",
      "Turbo run *",
      "Docker-compose *",
      "Docker compose *",
      "Mkdir -p .claude/*",
      "Mkdir -p apps/*",
      "Git status",
      "Git diff",
      "Git log",
      "Git add",
      "Git commit *",
      "Git branch",
      "Git checkout",
      "Git switch",
      "Git push",
      "Git pull",
      "Git fetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"if (Test-Path '${CLAUDE_PROJECT_DIR}/node_modules/.bin/eslint') { npx eslint --fix '${CLAUDE_FILE_PATH}' 2>$null; Write-Host 'Linted' }\""
          }
        ]
      }
    ]
  },
  "model": "claude-sonnet-4-6"
}
