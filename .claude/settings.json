{
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm run dev)",
      "Bash(pnpm run build)",
      "Bash(pnpm run test)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run clean)",
      "Bash(pnpm --filter *)",
      "Bash(nest *)",
      "Bash(vite)",
      "Bash(turbo run *)",
      "Bash(docker-compose *)",
      "Bash(docker compose *)",
      "Bash(mkdir -p *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(git add)",
      "Bash(git commit *)",
      "Bash(git branch)",
      "Bash(git checkout)",
      "Bash(git switch)",
      "Bash(git push)",
      "Bash(git pull)",
      "Bash(git fetch)",
      "Bash(gh *)",
      "Bash(curl *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"if (Test-Path '${CLAUDE_PROJECT_DIR}/node_modules/.bin/eslint') { npx eslint --fix '${CLAUDE_FILE_PATH}' 2>$null; Write-Host 'Linted' }\""
          }
        ]
      }
    ]
  },
  "model": "claude-sonnet-4-6"
}
